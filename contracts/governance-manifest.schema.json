{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://internal.example/schemas/governance-manifest.schema.json",
  "title": "Governance Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "apiVersion",
    "governanceVersion",
    "profile",
    "adapters",
    "evidence",
    "exceptions",
    "approval",
    "automation",
    "boardReview"
  ],
  "properties": {
    "apiVersion": {
      "type": "string",
      "const": "ai-dev-governance/v1"
    },
    "governanceVersion": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "profile": {
      "type": "string",
      "enum": ["strict-baseline", "strict-baseline+embedded"]
    },
    "adapters": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "providers/codex",
          "providers/claude",
          "profiles/embedded"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["planningPath", "validationPath", "releasePath"],
      "properties": {
        "planningPath": {"type": "string", "minLength": 1},
        "validationPath": {"type": "string", "minLength": 1},
        "releasePath": {"type": "string", "minLength": 1}
      }
    },
    "exceptions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registryPath", "reviewCadenceDays"],
      "properties": {
        "registryPath": {"type": "string", "minLength": 1},
        "reviewCadenceDays": {"type": "integer", "minimum": 1}
      }
    },
    "approval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["accountableRole", "requiredReviewers"],
      "properties": {
        "accountableRole": {"type": "string", "minLength": 1},
        "requiredReviewers": {"type": "integer", "minimum": 1}
      }
    },
    "automation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "stateMachine",
        "tiers",
        "boardTriggerRules",
        "humanInterventionRules"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["risk-tiered"]
        },
        "stateMachine": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ingest",
              "plan",
              "artifact-generation",
              "implementation",
              "validation",
              "board-review",
              "gate",
              "release"
            ]
          },
          "minItems": 8,
          "uniqueItems": true
        },
        "tiers": {
          "type": "object",
          "additionalProperties": false,
          "required": ["low", "medium", "high", "critical"],
          "properties": {
            "low": {"$ref": "#/$defs/tierPolicy"},
            "medium": {"$ref": "#/$defs/tierPolicy"},
            "high": {"$ref": "#/$defs/tierPolicy"},
            "critical": {"$ref": "#/$defs/tierPolicy"}
          }
        },
        "boardTriggerRules": {
          "type": "object",
          "additionalProperties": false,
          "required": ["highRequiresBoard", "criticalRequiresBoard"],
          "properties": {
            "highRequiresBoard": {"type": "boolean"},
            "criticalRequiresBoard": {"type": "boolean"}
          }
        },
        "humanInterventionRules": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "chairApprovalForHighCritical",
            "exceptionApprovalRequired",
            "compositionApprovalRequired"
          ],
          "properties": {
            "chairApprovalForHighCritical": {"type": "boolean"},
            "exceptionApprovalRequired": {"type": "boolean"},
            "compositionApprovalRequired": {"type": "boolean"}
          }
        }
      }
    },
    "boardReview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "packetTemplatePath",
        "meetingTemplatePath",
        "opportunityTemplatePath",
        "criticalFindingsBlockRelease",
        "selection",
        "composition"
      ],
      "properties": {
        "enabled": {"type": "boolean"},
        "packetTemplatePath": {"type": "string", "minLength": 1},
        "meetingTemplatePath": {"type": "string", "minLength": 1},
        "opportunityTemplatePath": {"type": "string", "minLength": 1},
        "sprintCritiqueCadenceDays": {"type": "integer", "minimum": 1},
        "accountabilityCadenceDays": {"type": "integer", "minimum": 1},
        "incidentReviewSlaHours": {"type": "integer", "minimum": 1},
        "criticalFindingsBlockRelease": {"type": "boolean"},
        "selection": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "requiredLenses",
            "minimumWeightedScore",
            "minimumRoleFitScore",
            "minimumEvidenceAccessibilityScore",
            "refreshCadence",
            "incidentTriggeredRefresh"
          ],
          "properties": {
            "requiredLenses": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string", "minLength": 1},
              "uniqueItems": true
            },
            "minimumWeightedScore": {"type": "number", "minimum": 1, "maximum": 5},
            "minimumRoleFitScore": {"type": "number", "minimum": 1, "maximum": 5},
            "minimumEvidenceAccessibilityScore": {"type": "number", "minimum": 1, "maximum": 5},
            "refreshCadence": {"type": "string", "enum": ["quarterly", "monthly"]},
            "incidentTriggeredRefresh": {"type": "boolean"}
          }
        },
        "composition": {
          "type": "object",
          "additionalProperties": false,
          "required": ["rosterPath", "approvalRecordPath", "minimumAlternatesPerSeat"],
          "properties": {
            "rosterPath": {"type": "string", "minLength": 1},
            "approvalRecordPath": {"type": "string", "minLength": 1},
            "minimumAlternatesPerSeat": {"type": "integer", "minimum": 1}
          }
        }
      }
    },
    "updateCadence": {
      "type": "string",
      "enum": ["monthly", "quarterly"]
    },
    "compatibility": {
      "type": "string",
      "enum": ["strict"]
    }
  },
  "$defs": {
    "tierPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["autoMerge", "requiredHumanApprovals", "boardReviewRequired"],
      "properties": {
        "autoMerge": {"type": "boolean"},
        "requiredHumanApprovals": {"type": "integer", "minimum": 0},
        "boardReviewRequired": {"type": "boolean"}
      }
    }
  }
}
