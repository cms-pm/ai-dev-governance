{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://internal.example/schemas/implementation-handoff.schema.json",
  "title": "Implementation Handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "handoffId",
    "sourceMeetingId",
    "riskTier",
    "adoptedActionIds",
    "chunkMappings",
    "acceptanceMappings",
    "riskDeltaPaths",
    "traceabilityPath",
    "owner",
    "status"
  ],
  "properties": {
    "handoffId": {"type": "string", "pattern": "^HOF-[0-9]{4}$"},
    "sourceMeetingId": {"type": "string", "pattern": "^MTG-[0-9]{4}$"},
    "riskTier": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
    "adoptedActionIds": {
      "type": "array",
      "items": {"type": "string", "pattern": "^ACT-[0-9]{3}$"},
      "minItems": 1,
      "uniqueItems": true
    },
    "chunkMappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["actionId", "chunkId"],
        "properties": {
          "actionId": {"type": "string", "pattern": "^ACT-[0-9]{3}$"},
          "chunkId": {"type": "string", "minLength": 1}
        }
      }
    },
    "acceptanceMappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["chunkId", "acceptanceId"],
        "properties": {
          "chunkId": {"type": "string", "minLength": 1},
          "acceptanceId": {"type": "string", "minLength": 1}
        }
      }
    },
    "riskDeltaPaths": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    },
    "traceabilityPath": {"type": "string", "minLength": 1},
    "owner": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["draft", "ready", "executing", "closed"]},
    "implementationComplexity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["applicability"],
      "allOf": [
        {
          "if": {
            "properties": {"applicability": {"const": "applicable"}}
          },
          "then": {
            "required": [
              "componentOwners",
              "namingReview",
              "placementReview",
              "complexityScores"
            ]
          }
        },
        {
          "if": {
            "properties": {"applicability": {"const": "not-applicable"}}
          },
          "then": {
            "required": ["notApplicableReason"]
          }
        }
      ],
      "properties": {
        "applicability": {"type": "string", "enum": ["applicable", "not-applicable"]},
        "notApplicableReason": {"type": "string", "minLength": 1},
        "componentOwners": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "namingReview": {"type": "string", "minLength": 1},
        "placementReview": {"type": "string", "minLength": 1},
        "mutableStateOwners": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "resourceOwners": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "stateMachines": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "taskLoops": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "publicSurface": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "lineCountEvidencePath": {"type": "string", "minLength": 1},
        "diagramEvidencePaths": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "complexityScores": {
          "type": "object",
          "additionalProperties": false,
          "required": ["changeAmplification", "cognitiveLoad", "unknownUnknowns"],
          "properties": {
            "changeAmplification": {"type": "integer", "minimum": 0, "maximum": 3},
            "cognitiveLoad": {"type": "integer", "minimum": 0, "maximum": 3},
            "unknownUnknowns": {"type": "integer", "minimum": 0, "maximum": 3}
          }
        },
        "exceptionIds": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      }
    }
  }
}
